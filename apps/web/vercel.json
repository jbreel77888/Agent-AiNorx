{
  "buildCommand": "cd ../.. && pnpm install --engine-strict=false && cd apps/web && SKIP_SENTRY=1 NEXT_PUBLIC_SENTRY_DSN= next build",
  "installCommand": "cd ../.. && pnpm install --engine-strict=false",
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true,
      "PRODUCTION": true
    }
  }
}
